{
  "name": "hello-world-app",
  "version": "1.0.0",
  "description": "Minimal Hello World app with TypeScript, Postgres, and Drizzle ORM",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome lint --write",
      "biome format --write"
    ]
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "postgres": "^3.4.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@vitest/ui": "^4.1.8",
    "drizzle-kit": "^0.21.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  }
}
